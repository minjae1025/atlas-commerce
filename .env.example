DATABASE_URL=postgres://atlas:atlas@postgres:5432/atlas
REDIS_URL=redis://redis:6379
LOG_LEVEL=info
GATEWAY_API_KEYS=demo-key-1,demo-key-2
PSP_FAIL_RATE=0

# Service port (set per-service, e.g. gateway=8080, catalog=7002, etc.)
PORT=7002

# Downstream service URLs
GATEWAY_URL=http://gateway:8080
CATALOG_URL=http://catalog:7002
INVENTORY_URL=http://inventory:7003
ORDERS_URL=http://orders:7004
PAYMENTS_URL=http://payments:7005
SETTLEMENT_URL=http://settlement:7006
RETURNS_URL=http://returns:7007
NOTIFICATIONS_URL=http://notifications:7008

# Synthetic monitor
API_KEY=demo-key-1
CYCLE_INTERVAL_MS=15000
